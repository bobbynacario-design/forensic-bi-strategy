// ─── Firestore Security Rules — Reference ─────────────────────────────────────
// Deploy via: firebase deploy --only firestore:rules
// Or paste into Firebase Console → Firestore → Rules tab.
//
// Context: Praxis app shares the Enclave Firebase project.
// These rules tighten the users collection so it is no longer queryable
// by email — which was the enumeration vector in the old invite flow.
// The new invite model uses pendingInvites + client-side self-claim,
// so the email-to-UID lookup is no longer needed.
// ──────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    // A user may only read and write their own document.
    // Collection-level queries (e.g. where("email","==",x)) are rejected
    // because no single-document rule can satisfy them — this is intentional.
    // The old email-to-UID lookup is replaced by the invite-claim flow.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Projects ───────────────────────────────────────────────────────────────
    // Read: authenticated members of the project only.
    // Create: any authenticated user (they become createdBy).
    // Update: existing members OR users whose email is in pendingInvites
    //         (self-claim path — claimPendingInvites in the app).
    // Delete: creator only.
    match /projects/{projectId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberIds;

      allow create: if request.auth != null;

      allow update: if request.auth != null
                    && (request.auth.uid in resource.data.memberIds
                        || request.auth.token.email in resource.data.pendingInvites);

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.createdBy;
    }

  }
}
